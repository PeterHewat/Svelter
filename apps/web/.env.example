# Copy to .env.local and set your Convex deployment URL.
# Run `bun run dev:convex` from the repo root, then paste the URL shown.
PUBLIC_CONVEX_URL=

# Clerk (from dashboard.clerk.com → API keys; setup can sync these)
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Google OAuth for Clerk + One Tap (optional — setup patches Clerk via CLI)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Playwright tasks E2E (optional — setup creates a test user via Clerk API)
# E2E_USER_EMAIL=e2e.test@your-domain.com
