{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Product web app (SvelteKit SPA)",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && bun ../../scripts/write-pages-edge-files.ts web",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "eslint .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "e2e:install": "playwright install",
    "e2e:debug": "playwright test --headed --debug",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@clerk/ui": "^1.23.0",
    "@repo/config": "workspace:*",
    "@repo/tokens": "workspace:*",
    "@repo/ui-svelte": "workspace:*",
    "@repo/utils": "workspace:*",
    "convex": "^1.42.0",
    "convex-svelte": "^0.14.0",
    "svelte-clerk": "^1.1.10"
  },
  "devDependencies": {
    "@clerk/testing": "^2.1.7",
    "@playwright/test": "^1.61.1",
    "@repo/test-utils": "workspace:*",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
