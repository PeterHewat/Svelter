{
  "name": "@repo/marketing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Marketing site (SvelteKit SSG)",
  "scripts": {
    "build:init": "bun scripts/bundle-init.ts",
    "dev": "bun run build:init && vite dev",
    "build": "bun run build:init && vite build && bun ../../scripts/optimize-marketing-build.ts && bun ../../scripts/write-pages-edge-files.ts marketing",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "eslint .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && bunx tsc -p src/init/tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "e2e:install": "playwright install",
    "e2e:debug": "playwright test --headed --debug",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "@repo/tokens": "workspace:*",
    "@repo/utils": "workspace:*",
    "marked": "^18.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.2"
  }
}
