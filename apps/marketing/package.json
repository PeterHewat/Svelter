{
  "name": "@repo/marketing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Marketing site (SvelteKit SSG)",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && bun ../../scripts/optimize-marketing-build.ts && bun ../../scripts/write-pages-edge-files.ts marketing",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "eslint .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "e2e:install": "playwright install",
    "e2e:debug": "playwright test --headed --debug",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@repo/config": "workspace:*",
    "@repo/tokens": "workspace:*",
    "@repo/ui-svelte": "workspace:*",
    "@repo/utils": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
