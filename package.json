{
  "name": "svelter-monorepo",
  "version": "0.1.0",
  "description": "Monorepo: Web SPA, Marketing SSG (SvelteKit + Convex + Clerk + Tailwind + Bun)",
  "author": "Peter Hewat <peter.hewat@gmail.com>",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.0.0"
  },
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/marketing",
    "convex",
    "packages/test-utils",
    "packages/ui-svelte",
    "packages/utils",
    "packages/tokens",
    "packages/config",
    "packages/env-core"
  ],
  "scripts": {
    "dev:convex": "bunx convex dev",
    "dev:web": "bun run --filter @repo/web dev",
    "dev:marketing": "bun run --filter @repo/marketing dev",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "setup": "bun scripts/setup.ts",
    "codegen": "bun scripts/generate.ts && bun scripts/assert-convex-generated.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "bun run codegen && bun run lint && bun run typecheck && bun scripts/assert-i18n-key-parity.ts",
    "verify": "bun run check && bun run test",
    "test": "bun run --filter '*' test && bun run test:scripts",
    "test:scripts": "bun test scripts/lib/",
    "test:web": "bun run --filter @repo/web test && bun run --filter @repo/ui-svelte test && bun run --filter @repo/utils test",
    "test:packages": "bun run --filter @repo/config test && bun run --filter @repo/env-core test",
    "test:integration": "bun run --filter @repo/utils test:integration",
    "e2e:install": "bunx playwright install chromium",
    "outdated": "bun outdated",
    "update": "bun update",
    "audit": "bun audit --audit-level=high",
    "build": "tsc -b",
    "build:all": "bun run build && bun run --filter '*' build",
    "clean": "rm -rf node_modules",
    "clean:ts": "tsc -b --clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": "prettier --write"
  },
  "overrides": {
    "ws": "^8.21.0",
    "devalue": "^5.8.1",
    "minimatch": "^10.2.5",
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0",
    "brace-expansion": "^5.0.6",
    "picomatch": "^4.0.4",
    "yaml": "^2.9.0",
    "@tootallnate/once": "^3.0.1",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.16",
    "srvx": "^0.11.16",
    "path-to-regexp": "^8.4.2",
    "undici": "^8.5.0",
    "esbuild": "^0.28.1",
    "js-cookie": "^3.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "clerk": "^1.5.0",
    "convex": "^1.41.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jose": "^6.2.3",
    "lint-staged": "^17.0.7",
    "opensrc": "^0.7.2",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "wrangler": "^4.102.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
